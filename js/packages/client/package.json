{
  "name": "@zodra/client",
  "version": "0.1.0",
  "description": "Type-safe API client for Zodra — auto-generated from Rails contracts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/supostat/zodra.git",
    "directory": "js/packages/client"
  },
  "keywords": ["zodra", "zod", "rails", "typescript", "api-client", "type-safe"],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
